PORT=3000

# tracker.delivery API
TRACKER_API_URL=https://apis.tracker.delivery/graphql
TRACKER_CLIENT_ID=your_client_id
TRACKER_CLIENT_SECRET=your_client_secret
# credential 발급일 (21일마다 갱신 필요). 갱신 후 이 날짜를 업데이트할 것.
TRACKER_CREDENTIAL_ISSUED_AT=2026-03-17

# APNs (Apple Push Notification service)
APNS_KEY_ID=your_key_id
APNS_TEAM_ID=your_team_id
APNS_KEY_PATH=./certs/AuthKey.p8
APNS_BUNDLE_ID=com.sangjin.waito

# Webhook
WEBHOOK_BASE_URL=https://your-server.com

# Admin
ADMIN_SECRET=your-admin-secret-here
